     "\:5f97\:5230\:5e73\:5747\:611f\:67d3\:6bd4\:4f8b"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "TotalInfection", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"TotalInfection", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"sol", "[", 
         RowBox[{"x", ",", "y", ",", "t"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "L"}], ",", "L"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "L"}], ",", "L"}], "}"}], ",", 
        RowBox[{"AccuracyGoal", "->", "4"}], ",", 
        RowBox[{"PrecisionGoal", "->", "4"}]}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{"4", "*", 
        RowBox[{"L", "^", "2"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "\:79bb\:6563\:5316\:65f6\:95f4\:70b9\:5e76\:5e76\:884c\:8ba1\:7b97", " ", 
